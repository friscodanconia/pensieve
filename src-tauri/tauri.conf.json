{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pensieve",
  "version": "0.1.0",
  "identifier": "com.soumyosinha.pensieve",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pensieve",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "2026 Soumyo Sinha",
    "shortDescription": "A writing app that syncs to your Obsidian vault",
    "macOS": {
      "entitlements": null,
      "minimumSystemVersion": "10.13",
      "infoPlist": "Info.plist"
    }
  }
}
